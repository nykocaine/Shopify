{%- doc -%}
Renders a single promotional block for the featured product list section, sized like a product card.
Desktop and mobile images are independent: each variant only renders when its own image is set.

@param {object} block - the promo block to render
@param {object} section
{%- enddoc -%}

{%- capture promo_content -%}
  {%- if block.settings.heading != blank or block.settings.content != blank or block.settings.subheading != blank -%}
    <div class="{{ block.settings.content_position }}">
      <div class="prose prose-justify-{{ block.settings.content_position | split: '-' | last }}">
        {%- if block.settings.subheading != blank -%}
          {%- render 'subheading', content: block.settings.subheading -%}
        {%- endif -%}

        {%- if block.settings.heading != blank -%}
          {%- render 'heading', content: block.settings.heading, style: block.settings.heading_size -%}
        {%- endif -%}

        {%- if block.settings.content != blank -%}
          <div class="max-w-xs">
            {{- block.settings.content -}}
          </div>
        {%- endif -%}

        {%- if block.settings.button_text -%}
          {%- render 'button',
              content: block.settings.button_text,
              href: block.settings.url,
              style: block.settings.style,
              external: block.settings.open_in_new_tab
          -%}
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
{%- endcapture -%}

{%- if block.settings.image != blank -%}
  <div class="product-list__promo {% if settings.product_listing_spacing == 'none' %}outline{% endif %} md-max:hidden color-scheme color-scheme--{{ block.settings.color_scheme.id }}" {% if settings.stagger_products %}reveal-on-scroll="true"{% endif %} style="--product-list-promo-row-span: 1; --product-list-promo-column-span: 1; border-radius: {{ section.settings.product_card_border_radius }}px; overflow: hidden;" {{ block.shopify_attributes }}>
    <div class="content-box min-h-full">
      <div class="content-box__background-media with-overlay" style="--overlay: {{ block.settings.overlay_color.rgb }} / {{ block.settings.overlay_opacity | divided_by: 100.0 }}">
        {%- render 'media', media: block.settings.image -%}
      </div>

      {{- promo_content -}}
    </div>
  </div>
{%- endif -%}

{%- if block.settings.mobile_image != blank -%}
  <div class="product-list__promo {% if settings.product_listing_spacing == 'none' %}outline{% endif %} md:hidden color-scheme color-scheme--{{ block.settings.color_scheme.id }}" {% if settings.stagger_products %}reveal-on-scroll="true"{% endif %} style="--product-list-promo-row-span: 1; --product-list-promo-column-span: 1; border-radius: {{ section.settings.product_card_border_radius }}px; overflow: hidden;" {{ block.shopify_attributes }}>
    <div class="content-box min-h-full">
      <div class="content-box__background-media with-overlay" style="--overlay: {{ block.settings.overlay_color.rgb }} / {{ block.settings.overlay_opacity | divided_by: 100.0 }}">
        {%- render 'media', media: block.settings.mobile_image -%}
      </div>

      {{- promo_content -}}
    </div>
  </div>
{%- endif -%}
