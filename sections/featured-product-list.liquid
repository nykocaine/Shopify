<style>
  #shopify-section-{{ section.id }} .product-list:not(.product-list--carousel) {
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .product-list__intro-block {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .product-list__intro-block > * {
    flex-grow: 1;
  }

  #shopify-section-{{ section.id }} .product-list__intro-block .content-box {
    position: relative;
    height: 100%;
    border-radius: var(--product-card-border-radius, 0);
  }

  #shopify-section-{{ section.id }} .product-list__intro-block .content-box__background-media,
  #shopify-section-{{ section.id }} .product-list__intro-block .content-box__background-media img {
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
    object-fit: cover;
    border-radius: var(--product-card-border-radius, 0);
  }

  #shopify-section-{{ section.id }} {
    --product-list-column-count: {{ section.settings.products_per_row_mobile | times: 1 }};
  }

  .progress-bar-container {
    margin-top: 2rem;
    position: relative;
  }

  .progress-bar {
    height: 100%;
    position: absolute;
    inset: 0;
  }

  {%- unless section.settings.show_progress_bar_mobile -%}
    @media screen and (max-width: 999px) {
      .progress-bar-container {
        display: none;
      }
    }
  {%- endunless -%}

  {%- unless section.settings.show_progress_bar_desktop -%}
    @media screen and (min-width: 1000px) {
      .progress-bar-container {
        display: none;
      }
    }
  {%- endunless -%}

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      --product-list-column-count: 2;
    }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} {
      --product-list-column-count: {{ section.settings.products_per_row_desktop }};
    }
  }
</style>

<div class="color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
  <div class="container">
    <div class="section-spacing section-spacing--tight">
        {%- assign product_list_id = 'product-list-' | append: section.id -%}

        {%- liquid
          assign product_list_class = ''

          if section.settings.stack_products_mobile == false and section.settings.stack_products_desktop == false
            assign product_list_class = 'product-list--carousel scroll-area bleed md:unbleed'
          elsif section.settings.stack_products_mobile == false
            assign product_list_class = 'md-max:product-list--carousel scroll-area bleed md:unbleed'
          elsif section.settings.stack_products_desktop == false
            assign product_list_class = 'md:product-list--carousel scroll-area'
          endif
        -%}

        <product-list id="{{ product_list_id }}" cell-selector=".product-card" class="product-list {{ product_list_class }}" style="--product-card-border-radius: {{ section.settings.product_card_border_radius }}px;" data-show-progress-bar-mobile="{{ section.settings.show_progress_bar_mobile }}" data-show-progress-bar-desktop="{{ section.settings.show_progress_bar_desktop }}">
          {%- if section.settings.intro_image != blank -%}
            <div class="product-list__intro-block color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
              <div class="@container/content-box h-full color-scheme color-scheme--{{ section.settings.intro_color_scheme.id }}">
                <div class="content-box">
                  <div class="content-box__background-media with-overlay" style="--overlay: {{ section.settings.intro_image_overlay.rgba }}">
                    {{- section.settings.intro_image | image_url: width: section.settings.intro_image.width | image_tag: sizes: '(max-width: 699px) 100vw, 25vw', widths: '200,300,400,600,800,1000,1200,1400,1600,1800', class: 'size-full' -}}
                  </div>

                  <div class="place-self-center">
                    <div class="prose prose-justify-center">
                      {%- if section.settings.intro_title != blank -%}
                        <p class="{{ section.settings.intro_title_tag }}">{{ section.settings.intro_title }}</p>
                      {%- endif -%}

                      {{- section.settings.intro_content -}}

                      {%- if section.settings.intro_button_text != blank -%}
                        {%- render 'button', content: section.settings.intro_button_text, href: section.settings.intro_button_link, style: section.settings.intro_button_style -%}
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          {%- endif -%}

          {%- capture sizes -%}(max-width: 699px) calc(100vw / {{ section.settings.products_per_row_mobile }} - 40px), (max-width: 999px) calc(100vw / {{ 3 | at_most: section.settings.products_per_row_desktop }} - 64px), calc((100vw - 96px) / {{ section.settings.products_per_row_desktop }}){%- endcapture -%}

          {%- liquid
            for product in section.settings.product_list
              render 'product-card', product: product, reveal: true, sizes: sizes, position: forloop.index
            else
              for i in (1..4)
                render 'product-card-placeholder', loop_index: i
              endfor
            endfor
          -%}
        </product-list>

        {%- if section.settings.show_progress_bar_mobile or section.settings.show_progress_bar_desktop -%}
          <div class="progress-bar-container v-stack gap-4" style="background-color: {{ section.settings.progress_bar_bg_color }}; height: {{ section.settings.progress_bar_height }}px;">
            <div class="progress-bar" style="background-color: {{ section.settings.progress_bar_color }}; width: {{ section.settings.progress_bar_initial_width }}%;"></div>
          </div>
        {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.featured_product_list.name",
  "class": "shopify-section--featured-product-list",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-1"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "t:sections.featured_product_list.product_list"
    },
    {
      "type": "checkbox",
      "id": "stack_products_mobile",
      "label": "t:global.product_list.stack_products_mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "stack_products_desktop",
      "label": "t:global.product_list.stack_products_desktop",
      "default": false
    },
    {
      "type": "header",
      "content": "Progress Bar"
    },
    {
      "type": "checkbox",
      "id": "show_progress_bar_mobile",
      "label": "Show progress bar on mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_progress_bar_desktop",
      "label": "Show progress bar on desktop",
      "default": false
    },
    {
      "type": "color",
      "id": "progress_bar_bg_color",
      "label": "Progress Bar Background Color",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "progress_bar_color",
      "label": "Progress Bar Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "progress_bar_height",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Progress Bar Height",
      "default": 2
    },
    {
      "type": "range",
      "id": "progress_bar_initial_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Ancho inicial de la barra de progreso",
      "default": 10
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "t:global.product_list.products_per_row_mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "products_per_row_desktop",
      "min": 2,
      "max": 4,
      "label": "t:global.product_list.products_per_row_desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "product_card_border_radius",
      "min": 0,
      "max": 25,
      "step": 1,
      "unit": "px",
      "label": "Radio del borde de la tarjeta de producto",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.featured_product_list.intro_block_category"
    },
    {
      "type": "color_scheme",
      "id": "intro_color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-2"
    },
    {
      "type": "image_picker",
      "id": "intro_image",
      "label": "t:global.image.image",
      "info": "t:sections.featured_product_list.intro_image_info"
    },
    {
      "type": "color",
      "id": "intro_image_overlay",
      "label": "t:global.colors.overlay_color",
      "alpha": true,
      "default": "#00000020"
    },
    {
      "type": "inline_richtext",
      "id": "intro_title",
      "label": "t:global.text.heading",
      "default": "The essentials"
    },
    {
      "type": "select",
      "id": "intro_title_tag",
      "label": "t:global.text.heading_size",
      "options": [
        {
          "value": "h3",
          "label": "Large"
        },
        {
          "value": "h4",
          "label": "Medium"
        },
        {
          "value": "h5",
          "label": "Small"
        },
        {
          "value": "h6",
          "label": "X-Small"
        },
        {
          "value": "h7",
          "label": "XX-Small"
        }
      ],
      "default": "h5"
    },
    {
      "type": "richtext",
      "id": "intro_content",
      "label": "t:global.text.content",
      "default": "<p>Share details of your store's product selection, or share a story that speaks to your customers.</p>"
    },
    {
      "type": "text",
      "id": "intro_button_text",
      "label": "t:global.text.link"
    },
    {
      "type": "url",
      "id": "intro_button_link",
      "label": "t:global.text.link_url"
    },
    {
      "type": "select",
      "id": "intro_button_style",
      "label": "t:global.text.button_style",
      "options": [
        {
          "value": "outline",
          "label": "t:global.text.button_style_options.outline"
        },
        {
          "value": "solid",
          "label": "t:global.text.button_style_options.solid"
        },
        {
          "value": "link",
          "label": "t:global.text.button_style_options.link"
        }
      ],
      "default": "outline"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_product_list.name",
      "category": "t:global.categories.products"
    }
  ]
}
{% endschema %}
