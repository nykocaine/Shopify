{%- if section.blocks.size > 0 -%}
  {%- liquid
    # When the section is just a carousel block + one other block, the carousel should take 60%
    # of the row and the other block the remaining 40% (whichever column each one lands in).
    assign carousel_count = 0
    assign carousel_block_index = 0

    for block in section.blocks
      if block.type == 'carousel'
        assign carousel_count = carousel_count | plus: 1

        if carousel_block_index == 0
          assign carousel_block_index = forloop.index
        endif
      endif
    endfor

    assign use_carousel_split = false

    if carousel_count == 1 and section.blocks.size == 2
      assign use_carousel_split = true
    endif
  -%}

  <style>
    #shopify-section-{{ section.id }} {
      --media-blocks-grid: {% if section.settings.stack_on_mobile %}auto-flow / minmax(0, 1fr){% else %}auto / auto-flow 78vw{% endif %};
      {%- comment -%}
        When column_spacing is 'none' the gap is forced to 0px even if add_border is enabled.
        The original 1px gap for add_border was meant to reveal a hairline between cards, but it
        breaks the "single continuous piece" look required when there is no spacing between cards
        (it also creates a 1px seam that clashes with the shared outer corner radius). The bordered
        look (.media-blocks__item--bordered) still renders its own border on top of each card, so
        visually nothing is lost by removing the extra 1px gap.
      {%- endcomment -%}
      --media-blocks-gap: {% if section.settings.column_spacing == 'none' %}0px{% elsif section.settings.column_spacing == 'sm' %}calc(var(--container-gutter) / 2){% elsif section.settings.column_spacing == 'md' %}var(--container-gutter){% elsif section.settings.column_spacing == 'lg' %}calc(var(--container-gutter) * 1.5){% endif %};
    }

    @media screen and (min-width: 700px) {
      #shopify-section-{{ section.id }} {
        --media-blocks-grid: {% if section.settings.stack_on_mobile or section.blocks.size <= 2 %}auto / repeat(2, minmax(0, 1fr)){% else %}auto / auto-flow 45vw{% endif %};
      }
    }

    @media screen and (min-width: 1000px) {
      #shopify-section-{{ section.id }} {
        --media-blocks-grid: auto-flow / {% if use_carousel_split %}{% if carousel_block_index == 1 %}3fr 2fr{% else %}2fr 3fr{% endif %}{% else %}repeat({{ section.settings.items_per_row }}, minmax(0, 1fr)){% endif %};
      }
    }

    @media screen and (pointer: fine) {
      {%- for block in section.blocks -%}
        {%- if block.settings.change_color_scheme_on_hover -%}
          {%- comment -%}
          Some colors are not used in this context, so we only output the necessary variables
          {%- endcomment -%}

          {%- assign color_scheme = block.settings.color_scheme -%}

          #block-{{ block.id }} {
            transition: all 0.2s ease-in-out;
          }

          #block-{{ block.id }} .content-box__background-media {
            opacity: 0;
            transition: opacity 0.2s ease-in-out;
          }

          #block-{{ block.id }} .link {
            transition: color 0s ease-in-out,  background-size 0.3s ease-in-out;
          }

          {%- if block.settings.image != blank -%}
            #block-{{ block.id }}:hover {
              {%- comment -%}
              On hover, this forces to re-use the same background as the initial color scheme, which avoids a flash of the destination background
              {%- endcomment -%}
              --background: {% if color_scheme.settings.background == 'rgba(0,0,0,0)' %}0 0 0 / 0{% else %}{{ color_scheme.settings.background.rgb }}{% endif %};
            }
          {%- endif -%}

          #block-{{ block.id }}:not(:hover) {
            --accent: {{ color_scheme.settings.primary_button_background.rgb }};
            --background: {% if color_scheme.settings.background == 'rgba(0,0,0,0)' %}0 0 0 / 0{% else %}{{ color_scheme.settings.background.rgb }}{% endif %};
            --background-gradient: {{ color_scheme.settings.background_gradient }};
            --text-color: {{ color_scheme.settings.text_color.rgb }};
            --border-color: {{ color_scheme.settings.text_color.rgb }} / 0.1;
            --heading-highlight-accent-color: {{ color_scheme.settings.heading_highlight_accent_color.rgb }};
            --heading-highlight-text-color: {{ color_scheme.settings.heading_highlight_text_color.rgb }};
            --button-background-primary: {{ color_scheme.settings.primary_button_background.rgb }};
            --button-text-primary: {{ color_scheme.settings.primary_button_text_color.rgb }};

            {%- liquid
              assign subheading_has_border = true
              assign subheading_has_background = true
      
              if color_scheme.settings.subheading_background == blank or color_scheme.settings.subheading_background == 'rgba(0,0,0,0)' or color_scheme.settings.subheading_background == color_scheme.settings.background
                assign subheading_has_background = false
              endif
      
              if color_scheme.settings.subheading_border_color == blank or color_scheme.settings.subheading_border_color == 'rgba(0,0,0,0)'
                assign subheading_has_border = false
              endif
            -%}
      
            --subheading-background: {% if subheading_has_background %}{{ color_scheme.settings.subheading_background.rgb }}{% else %}0 0 0 / 0.0{% endif %};
            --subheading-border: {% if subheading_has_border %}1px solid rgb({{ color_scheme.settings.subheading_border_color.rgb }}){% else %}none{% endif %};
            --subheading-text-color: {{ color_scheme.settings.subheading_text_color.rgb }};
            --subheading-has-padding: {% if subheading_has_border or subheading_has_background %}1{% else %}0{% endif %};
          }

          #block-{{ block.id }}:hover .content-box__background-media {
            opacity: 1;
          }
        {%- endif -%}
      {%- endfor -%}
    }

    /* ---------------------------------------------------------------------
       Corner radius (outer corners only)
       ------------------------------------------------------------------- */
    #shopify-section-{{ section.id }} {
      {%- comment -%}
        Auto mode scales the radius with the viewport but the floor is relative to the merchant's
        chosen corner_radius (50% of it) instead of a fixed px value. A fixed low floor (e.g. 4px)
        made the radius collapse hard on mobile viewports (1.2vw is only ~4-5px around 375-430px)
        while desktop viewports almost always hit the max, making the two look inconsistent.
      {%- endcomment -%}
      --media-blocks-corner-radius: {% if section.settings.auto_corner_radius %}clamp({{ section.settings.corner_radius | times: 0.5 | round }}px, 3vw, {{ section.settings.corner_radius }}px){% else %}{{ section.settings.corner_radius }}px{% endif %};
    }

    #shopify-section-{{ section.id }} .media-blocks__item {
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .media-blocks__item .content-box,
    #shopify-section-{{ section.id }} .media-blocks__item .content-box__background-media {
      border-radius: inherit;
      overflow: hidden;
    }

    {%- if section.settings.column_spacing == 'none' -%}
      {%- comment -%}
        No spacing between cards: they form a single continuous piece, so the radius only
        applies to the outer corners of the whole set (first item on one end, last item on
        the other), never on the touching inner edges between cards.
      {%- endcomment -%}

      /* Desktop / tablet: items laid out horizontally -> radius on the left of the first item and the right of the last item */
      @media screen and (min-width: 700px) {
        #shopify-section-{{ section.id }} .media-blocks > *:first-child .media-blocks__item,
        #shopify-section-{{ section.id }} .media-blocks > *:first-child.media-blocks__item {
          border-top-left-radius: var(--media-blocks-corner-radius);
          border-bottom-left-radius: var(--media-blocks-corner-radius);
        }

        #shopify-section-{{ section.id }} .media-blocks > *:last-child .media-blocks__item,
        #shopify-section-{{ section.id }} .media-blocks > *:last-child.media-blocks__item {
          border-top-right-radius: var(--media-blocks-corner-radius);
          border-bottom-right-radius: var(--media-blocks-corner-radius);
        }
      }

      /* Mobile */
      @media screen and (max-width: 699px) {
        {%- if section.settings.stack_on_mobile -%}
          /* Items are stacked vertically -> radius on the top of the first item and the bottom of the last item */
          #shopify-section-{{ section.id }} .media-blocks > *:first-child .media-blocks__item,
          #shopify-section-{{ section.id }} .media-blocks > *:first-child.media-blocks__item {
            border-top-left-radius: var(--media-blocks-corner-radius);
            border-top-right-radius: var(--media-blocks-corner-radius);
          }

          #shopify-section-{{ section.id }} .media-blocks > *:last-child .media-blocks__item,
          #shopify-section-{{ section.id }} .media-blocks > *:last-child.media-blocks__item {
            border-bottom-left-radius: var(--media-blocks-corner-radius);
            border-bottom-right-radius: var(--media-blocks-corner-radius);
          }
        {%- else -%}
          /* Items still scroll horizontally on mobile -> same behavior as desktop/tablet */
          #shopify-section-{{ section.id }} .media-blocks > *:first-child .media-blocks__item,
          #shopify-section-{{ section.id }} .media-blocks > *:first-child.media-blocks__item {
            border-top-left-radius: var(--media-blocks-corner-radius);
            border-bottom-left-radius: var(--media-blocks-corner-radius);
          }

          #shopify-section-{{ section.id }} .media-blocks > *:last-child .media-blocks__item,
          #shopify-section-{{ section.id }} .media-blocks > *:last-child.media-blocks__item {
            border-top-right-radius: var(--media-blocks-corner-radius);
            border-bottom-right-radius: var(--media-blocks-corner-radius);
          }
        {%- endif -%}
      }
    {%- else -%}
      {%- comment -%}
        Any spacing (sm/md/lg) leaves a visible gap between cards, so each card reads as its
        own independent piece and gets the radius on all four of its corners.
      {%- endcomment -%}
      #shopify-section-{{ section.id }} .media-blocks__item {
        border-radius: var(--media-blocks-corner-radius);
      }
    {%- endif -%}
  </style>

  {%- assign allow_transparent_header = false -%}

  {%- if section.settings.allow_transparent_header and section.settings.subheading == blank and section.settings.title == blank and section.settings.content == blank and section.settings.add_horizontal_spacing == false and section.settings.column_spacing == 'none' -%}
    {%- assign allow_transparent_header = true -%}
  {%- endif -%}

  <div {% if allow_transparent_header %}allow-transparent-header{% endif %} class="color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
    <div class="{% if section.settings.add_horizontal_spacing %}container{% endif %} {% unless allow_transparent_header %}section-spacing{% endunless %}">
      <div class="section-stack">
        {%- if section.settings.subheading != blank or section.settings.title != blank or section.settings.content != blank -%}
          <div class="{% unless section.settings.add_horizontal_spacing %}container{% endunless %}">
            <div class="prose prose-justify-{{ section.settings.text_alignment }}">
              {%- if section.settings.subheading != blank -%}
                {%- render 'subheading', content: section.settings.subheading -%}
              {%- endif -%}

              {%- if section.settings.title != blank -%}
                {%- if section.settings.scrolling_title -%}
                  <h2 class="{{ section.settings.heading_tag }}">
                    <marquee-text speed="0.3" direction="start-to-end" class="scrolling-content bleed">
                      <span class="scrolling-content__item" style="font-size: var(--text-{{ section.settings.heading_tag }})">
                        <span class="scrolling-content__text">
                          {%- render 'heading', content: section.settings.title, balance_text: true, style: section.settings.heading_tag, html_tag: 'span', instant: true -%}
                        </span>

                        {%- if section.settings.scrolling_title_separator != 'none' -%}
                          <span class="shape shape--{{ section.settings.scrolling_title_separator }}" style="font-size: var(--text-{{ section.settings.heading_tag }})" aria-hidden="true"></span>
                        {%- endif -%}
                      </span>
                    </marquee-text>
                  </h2>
                {%- else -%}
                  {%- render 'heading', content: section.settings.title, balance_text: true, style: section.settings.heading_tag, html_tag: 'h2' -%}
                {%- endif -%}
              {%- endif -%}

              {%- if section.settings.content != blank -%}
                <div class="max-w-xs">
                  {{- section.settings.content -}}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        <div class="media-blocks {% unless section.settings.stack_on_mobile %}scroll-area bleed{% endunless %}">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'image_with_text' or 'video_with_text' -%}
                {%- liquid
                  # If the merchant choose to show a color scheme on hover, we force it on mobile, so we apply the hover one by default so that
                  # it is the default one on touch devices
                  if block.settings.change_color_scheme_on_hover
                    assign color_scheme = block.settings.color_scheme_hover
                  else
                    assign color_scheme = block.settings.color_scheme
                  endif

                  assign can_make_block_clickable = true

                  if block.settings.subheading contains '</a>' or block.settings.text contains '</a>' or block.settings.title contains '</a>'
                    assign can_make_block_clickable = false
                  endif
                -%}

                {%- capture block_content -%}
                  <div class="content-box h-full min-h-{{ section.settings.mobile_block_size }} md:min-h-{{ section.settings.block_size }}">
                    {%- capture sizes_attribute -%}(max-width: 699px) 100vw, (max-width: 999px) 50vw, {{ 100.0 | divided_by: section.settings.items_per_row | round }}vw{%- endcapture -%}

                    {%- if block.settings.image != blank or block.settings.video != blank -%}
                      <div class="content-box__background-media">
                        {%- liquid
                          assign loading_attribute = nil

                          if section.index > 1 or forloop.index > 3
                            assign loading_attribute = 'lazy'
                          endif

                          if block.type == 'image_with_text' and block.settings.image != blank
                            echo block.settings.image | image_url: width: block.settings.image.width | image_tag: loading: loading_attribute, sizes: sizes_attribute, widths: '300,400,500,600,800,1000,1200,1400,1600,1800', class: 'size-full'
                          elsif block.type == 'video_with_text' and block.settings.video != blank
                            render 'media', media: block.settings.video, autoplay: true, loop: true, controls: false, sizes: sizes_attribute
                          endif
                        -%}
                      </div>
                    {%- elsif block.settings.color_scheme.settings.background == 'rgba(0,0,0,0)' and request.design_mode or request.visual_preview_mode -%}
                      <div class="content-box__background-media">
                        {{- 'collection-apparel-1' | placeholder_svg_tag: 'block' -}}
                      </div>
                    {%- endif -%}

                    {%- liquid
                      assign top_left_content = ''
                      assign top_center_content = ''
                      assign top_right_content = ''
                      assign middle_left_content = ''
                      assign middle_center_content = ''
                      assign middle_right_content = ''
                      assign bottom_left_content = ''
                      assign bottom_center_content = ''
                      assign bottom_right_content = ''
                    -%}

                    {%- assign content_array = 'icon,subheading,heading,text,link' | split: ',' -%}

                    {%- for content_type in content_array -%}
                      {%- capture content -%}
                        {%- case content_type -%}
                          {%- when 'icon' -%}
                            {%- if block.settings.custom_icon != blank -%}
                              {%- render 'icon', image: block.settings.custom_icon, width: block.settings.icon_width, mobile_width: block.settings.mobile_icon_width -%}
                            {%- else -%}
                              {%- render 'icon' with block.settings.icon, width: block.settings.icon_width, mobile_width: block.settings.mobile_icon_width -%}
                            {%- endif -%}

                          {%- when 'subheading' -%}
                            {%- if block.settings.subheading != blank -%}
                              {%- render 'subheading', content: block.settings.subheading -%}
                            {%- endif -%}

                          {%- when 'heading' -%}
                            {%- if block.settings.title != blank -%}
                              {%- if block.settings.scrolling_title -%}
                                <p class="{{ block.settings.heading_tag }} {% if block.settings.show_text_vertically %}h-full{% else %}column-bleed{% endif %}">
                                  <marquee-text speed="0.3" direction="start-to-end" {% if block.settings.show_text_vertically %}vertical{% endif %} class="scrolling-content {% if block.settings.show_text_vertically %}scrolling-content--vertical h-full{% endif %}">
                                    <span class="scrolling-content__item" style="font-size: var(--text-{{ block.settings.heading_tag }})">
                                      <span class="scrolling-content__text">
                                        {%- render 'heading', content: block.settings.title, style: block.settings.heading_tag, html_tag: 'span', instant: true, show_vertically: block.settings.show_text_vertically -%}
                                      </span>

                                      {%- if block.settings.scrolling_title_separator != 'none' -%}
                                        <span class="shape shape--{{ block.settings.scrolling_title_separator }}" style="font-size: var(--text-{{ block.settings.heading_tag }})" aria-hidden="true"></span>
                                      {%- endif -%}
                                    </span>
                                  </marquee-text>
                                </p>
                              {%- else -%}
                                {%- render 'heading', content: block.settings.title, style: block.settings.heading_tag, show_vertically: block.settings.show_text_vertically -%}
                              {%- endif -%}
                            {%- endif -%}

                          {%- when 'text' -%}
                            {% if block.settings.text != blank %}
                              <div class="max-w-sm">
                                {{- block.settings.text -}}
                              </div>
                            {%- endif -%}

                          {%- when 'link' -%}
                            {%- liquid
                              if block.settings.link_text != blank
                                if can_make_block_clickable
                                  render 'button', content: block.settings.link_text, type: 'button', style: block.settings.button_style
                                else
                                  render 'button', content: block.settings.link_text, href: block.settings.link_url, style: block.settings.button_style
                                endif
                              endif
                            -%}
                        {%- endcase -%}
                      {%- endcapture -%}

                      {%- capture content_position_key -%}{{ content_type }}_position{%- endcapture -%}

                      {%- if content_type == 'heading' and block.settings.scrolling_title and block.settings.show_text_vertically -%}
                        <div class="row-span-full justify-self-{% if block.settings[content_position_key] contains 'left' %}start{% elsif block.settings[content_position_key] contains 'right' %}end{% else %}center{% endif %}">
                          {{ content }}
                        </div>
                      {%- else -%}
                        {%- liquid
                          case block.settings[content_position_key]
                            when 'top_left'
                              assign top_left_content = top_left_content | append: content
                            when 'top_center'
                              assign top_center_content = top_center_content | append: content
                            when 'top_right'
                              assign top_right_content = top_right_content | append: content
                            when 'middle_left'
                              assign middle_left_content = middle_left_content | append: content
                            when 'middle_center'
                              assign middle_center_content = middle_center_content | append: content
                            when 'middle_right'
                              assign middle_right_content = middle_right_content | append: content
                            when 'bottom_left'
                              assign bottom_left_content = bottom_left_content | append: content
                            when 'bottom_center'
                              assign bottom_center_content = bottom_center_content | append: content
                            when 'bottom_right'
                              assign bottom_right_content = bottom_right_content | append: content
                          endcase
                        -%}
                      {%- endif -%}
                    {%- endfor -%}

                    <div class="placement-grid">
                      {% if top_left_content != blank %}
                        <div class="align-self-start">
                          <div class="prose prose-justify-start">
                            {{- top_left_content -}}
                          </div>
                        </div>
                      {%- endif -%}

                      {% if top_center_content != blank %}
                        <div class="align-self-start">
                          <div class="prose prose-justify-center">
                            {{- top_center_content -}}
                          </div>
                        </div>
                      {%- endif -%}

                      {% if top_right_content != blank %}
                        <div class="align-self-start">
                          <div class="prose prose-justify-end">
                            {{- top_right_content -}}
                          </div>
                        </div>
                      {%- endif -%}

                      {% if middle_left_content != blank %}
                        <div class="align-self-center">
                          <div class="prose prose-justify-start">
                            {{- middle_left_content -}}
                          </div>
                        </div>
                      {%- endif -%}

                      {% if middle_center_content != blank %}
                        <div class="align-self-center">
                          <div class="prose prose-justify-center">
                            {{- middle_center_content -}}
                          </div>
                        </div>
                      {%- endif -%}

                      {% if middle_right_content != blank %}
                        <div class="align-self-center">
                          <div class="prose prose-justify-end">
                            {{- middle_right_content -}}
                          </div>
                        </div>
                      {%- endif -%}

                      {% if bottom_left_content != blank %}
                        <div class="align-self-end">
                          <div class="prose prose-justify-start">
                            {{- bottom_left_content -}}
                          </div>
                        </div>
                      {%- endif -%}

                      {% if bottom_center_content != blank %}
                        <div class="align-self-end">
                          <div class="prose prose-justify-center">
                            {{- bottom_center_content -}}
                          </div>
                        </div>
                      {%- endif -%}

                      {% if bottom_right_content != blank %}
                        <div class="align-self-end">
                          <div class="prose prose-justify-end">
                            {{- bottom_right_content -}}
                          </div>
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endcapture -%}

                <media-block class="h-full">
                  {%- if can_make_block_clickable and block.settings.link_url != blank -%}
                    <a href="{{ block.settings.link_url }}" id="block-{{ block.id }}" class="media-blocks__item {% if section.settings.add_border %}media-blocks__item--bordered{% endif %} @container/content-box color-scheme color-scheme--{{ color_scheme.id }}" {{ block.shopify_attributes }}>
                      {{- block_content -}}
                    </a>
                  {%- else -%}
                    <div id="block-{{ block.id }}" class="media-blocks__item {% if section.settings.add_border %}media-blocks__item--bordered{% endif %} @container/content-box color-scheme color-scheme--{{ color_scheme.id }}" {{ block.shopify_attributes }}>
                      {{- block_content -}}
                    </div>
                  {%- endif -%}
                </media-block>

              {%- when 'empty_item' -%}
                <div class="media-blocks__item color-scheme color-scheme--{{ block.settings.color_scheme.id }} md-max:hidden" {{ block.shopify_attributes }}>
                  <!-- Empty item -->
                </div>

              {%- when 'carousel' -%}
                {%- liquid
                  assign carousel_slide_count = 0

                  for i in (1..8)
                    capture image_key
                      echo 'image_'
                      echo i
                    endcapture

                    capture video_key
                      echo 'video_'
                      echo i
                    endcapture

                    capture heading_key
                      echo 'heading_'
                      echo i
                    endcapture

                    capture text_key
                      echo 'text_'
                      echo i
                    endcapture

                    assign slide_image = block.settings[image_key]
                    assign slide_video = block.settings[video_key]
                    assign slide_heading = block.settings[heading_key]
                    assign slide_text = block.settings[text_key]

                    if slide_image != blank or slide_video != blank or slide_heading != blank or slide_text != blank
                      assign carousel_slide_count = carousel_slide_count | plus: 1
                    endif
                  endfor

                  # Video width (desktop): only meaningful when the section has a fixed desktop block
                  # size to derive a width from (block_size 'auto' sizes itself off the video/image's own
                  # ratio already, and 'none' means the feature is off). Both the aspect-ratio and the
                  # target height are resolved to explicit, deterministic CSS values (not intrinsic sizing
                  # like max-content or a bare min-height) precisely so that the derived width is exact,
                  # instead of relying on any browser auto-sizing edge case.
                  assign carousel_video_aspect_ratio = nil

                  if section.settings.carousel_video_width != 'none' and section.settings.block_size != 'auto'
                    case section.settings.carousel_video_width
                      when '4-5'
                        assign carousel_video_aspect_ratio = '4 / 5'
                        assign carousel_video_width_ratio = 0.8
                      when '3-4'
                        assign carousel_video_aspect_ratio = '3 / 4'
                        assign carousel_video_width_ratio = 0.75
                      when '9-16'
                        assign carousel_video_aspect_ratio = '9 / 16'
                        assign carousel_video_width_ratio = 0.5625
                    endcase

                    case section.settings.block_size
                      when 'sm'
                        assign carousel_video_box_height = 'clamp(15rem, 35vmax, 25rem)'
                      when 'md'
                        assign carousel_video_box_height = 'clamp(20rem, 45vmax, 35rem)'
                      when 'lg'
                        assign carousel_video_box_height = 'clamp(25rem, 55vmax, 45rem)'
                      when 'fill'
                        assign carousel_video_box_height = 'calc(100svh - var(--sticky-area-height, 0px))'
                    endcase
                  endif
                -%}

                <style>
                  #carousel-{{ block.id }} {
                    grid: auto / auto-flow 85%;
                    gap: .75rem;
                    display: grid;
                  }

                  @media screen and (min-width: 700px) {
                    #carousel-{{ block.id }} {
                      grid: auto / auto-flow {% if carousel_video_aspect_ratio %}calc({{ carousel_video_box_height }} * {{ carousel_video_width_ratio }}){% else %}45%{% endif %};
                    }

                    {%- if carousel_video_aspect_ratio -%}
                      {%- comment -%}
                        The column width above is the same calc() as this height * ratio, computed
                        explicitly instead of relying on intrinsic/max-content sizing - so image-only
                        slides in the same carousel (which don't match :has(video-media) below and so
                        keep their existing min-height) still land in a column of the correct, exact
                        width, rather than risking collapsing to zero under max-content sizing.
                      {%- endcomment -%}
                      #carousel-{{ block.id }} .content-box:has(video-media) {
                        height: {{ carousel_video_box_height }};
                        aspect-ratio: {{ carousel_video_aspect_ratio }};
                        width: auto;
                      }
                    {%- endif -%}
                  }

                  #carousel-{{ block.id }} video-media > img,
                  #carousel-{{ block.id }} video-media > video {
                    opacity: 1 !important;
                  }

                  #carousel-{{ block.id }} video-media > img {
                    z-index: 1;
                    transition: opacity .3s ease;
                  }

                  #carousel-{{ block.id }} video-media > img.carousel-video-poster-hidden {
                    opacity: 0 !important;
                    pointer-events: none;
                  }

                  /* If autoplay is blocked by the browser, the shared video-media component falls back to
                     the native play button (sets [suspended] + controls) so playback can still be started
                     manually. Our poster image would otherwise sit on top of it and hide/block taps. */
                  #carousel-{{ block.id }} video-media[suspended] > img {
                    opacity: 0 !important;
                    pointer-events: none;
                  }

                  #carousel-{{ block.id }} .carousel-video-tap-to-unmute {
                    cursor: pointer;
                  }

                  /* Root cause of controls inheriting Color Scheme colors: .circle-button (theme-wide,
                     assets/theme.css) paints a scheme-derived tint via its own ::before pseudo-element on
                     top of whatever background we set, and shifts icon `color` on hover via a separate
                     scheme-derived color-mix(). Both are killed below for our 3 buttons specifically, the
                     same way the theme already opts individual variants out via ".circle-button--outline:
                     before { content: none; }" - reusing that existing pattern rather than patching around
                     it with extra specificity. From here on, background/border/icon color come exclusively
                     from the --control-button-* variables (Global > Controls). */
                  #carousel-{{ block.id }} .carousel-video-sound-toggle:before,
                  #carousel-{{ block.id }} .carousel-video-pause-toggle:before,
                  #carousel-{{ block.id }} .carousel-video-product-link:before {
                    content: none;
                  }

                  #carousel-{{ block.id }} .carousel-video-sound-toggle,
                  #carousel-{{ block.id }} .carousel-video-pause-toggle,
                  #carousel-{{ block.id }} .carousel-video-product-link {
                    transition: opacity 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
                  }

                  /* Desktop: Comprar / Sonido / Play-Pausa are visible from the start and stay visible for
                     good - no entrance fade, never hidden for inactivity. */
                  @media screen and (pointer: fine) {
                    #carousel-{{ block.id }} .carousel-video-sound-toggle,
                    #carousel-{{ block.id }} .carousel-video-pause-toggle,
                    #carousel-{{ block.id }} .carousel-video-product-link {
                      opacity: 1;
                      pointer-events: auto;
                    }

                    #carousel-{{ block.id }} .carousel-video-pause-toggle:not([disabled]):hover,
                    #carousel-{{ block.id }} .carousel-video-sound-toggle:not([disabled]):hover,
                    #carousel-{{ block.id }} .carousel-video-product-link:not([disabled]):hover {
                      background: var(--control-button-hover-background-color, var(--control-button-background-color, #333333));
                      color: var(--control-button-icon-color, #ffffff);
                    }
                  }

                  /* Mobile: hidden by default, fade in as a single group (revealControls() below), and
                     fade out again after a few seconds of inactivity (scheduleHide() below). */
                  @media screen and (pointer: coarse) {
                    #carousel-{{ block.id }} .carousel-video-sound-toggle,
                    #carousel-{{ block.id }} .carousel-video-pause-toggle,
                    #carousel-{{ block.id }} .carousel-video-product-link {
                      opacity: 0;
                      pointer-events: none;
                    }

                    #carousel-{{ block.id }} .carousel-video-sound-toggle.is-visible,
                    #carousel-{{ block.id }} .carousel-video-pause-toggle.is-visible,
                    #carousel-{{ block.id }} .carousel-video-product-link.is-visible {
                      opacity: 1;
                      pointer-events: auto;
                    }
                  }

                  /* Text mode reuses the theme's body text styling as-is (no independent typography). */
                  #carousel-{{ block.id }} .carousel-video-product-link__text {
                    font: var(--text-font-style) var(--text-font-weight) var(--text-base) / var(--text-line-height) var(--text-font-family);
                    text-transform: var(--text-transform);
                    letter-spacing: var(--text-letter-spacing);
                    white-space: nowrap;
                  }
                </style>

                <div class="media-blocks__item {% if section.settings.add_border %}media-blocks__item--bordered{% endif %} color-scheme color-scheme--{{ block.settings.color_scheme.id }}" style="padding: min(1.25rem, var(--container-gutter));" {{ block.shopify_attributes }}>
                  <div class="v-stack gap-4">
                    <div style="border-radius: var(--media-blocks-corner-radius); overflow: hidden;">
                    <product-list id="carousel-{{ block.id }}" cell-selector=".snap-start" class="scroll-area snap-x">
                      {%- for i in (1..8) -%}
                        {%- capture image_key -%}image_{{ i }}{%- endcapture -%}
                        {%- capture video_key -%}video_{{ i }}{%- endcapture -%}
                        {%- capture product_key -%}product_{{ i }}{%- endcapture -%}
                        {%- capture heading_key -%}heading_{{ i }}{%- endcapture -%}
                        {%- capture text_key -%}text_{{ i }}{%- endcapture -%}

                        {%- assign slide_image = block.settings[image_key] -%}
                        {%- assign slide_video = block.settings[video_key] -%}
                        {%- assign slide_product = block.settings[product_key] -%}
                        {%- assign slide_heading = block.settings[heading_key] -%}
                        {%- assign slide_text = block.settings[text_key] -%}

                        {%- if slide_image != blank or slide_video != blank or slide_heading != blank or slide_text != blank -%}
                          <div class="snap-start">
                            <div class="content-box h-full min-h-{{ block.settings.mobile_block_size }} md:min-h-{{ section.settings.block_size }}" style="border-radius: var(--media-blocks-corner-radius); overflow: hidden;">
                              <div class="content-box__background-media {% if slide_video != blank %}carousel-video-tap-to-unmute{% endif %}">
                                {%- if slide_video != blank -%}
                                  {%- render 'media', media: slide_video, autoplay: false, muted: true, controls: false, show_play_button: false, playsinline: true, sizes: '85vw' -%}

                                  {%- capture control_button_style -%}
                                    width: var(--control-button-size, 1.75rem); height: var(--control-button-size, 1.75rem); background: var(--control-button-background-color, #000000); border: var(--control-button-border-width, 1px) solid var(--control-button-border-color, #000000); border-radius: var(--control-button-border-radius, 100%); color: var(--control-button-icon-color, #ffffff);
                                  {%- endcapture -%}

                                  {%- assign show_product_button = false -%}

                                  {%- if block.settings.show_product_button and slide_product != blank -%}
                                    {%- assign show_product_button = true -%}

                                    {%- capture product_button_style -%}
                                      height: var(--control-button-size, 1.75rem); background: var(--control-button-background-color, #000000); border: var(--control-button-border-width, 1px) solid var(--control-button-border-color, #000000); border-radius: var(--control-button-border-radius, 100%); color: var(--control-button-icon-color, #ffffff); {% if block.settings.product_button_type == 'text' %}width: auto; padding-inline: 0.75rem;{% else %}width: var(--control-button-size, 1.75rem);{% endif %}
                                    {%- endcapture -%}
                                  {%- endif -%}

                                  <div class="h-stack gap-2" style="width: auto; height: auto; position: absolute; inset-block-start: 1rem; inset-inline-end: 1rem; z-index: 1;">
                                    {%- if show_product_button -%}
                                      <a href="{{ slide_product.url }}" class="carousel-video-product-link circle-button" style="{{ product_button_style }}">
                                        {%- if block.settings.product_button_type == 'text' -%}
                                          <span class="carousel-video-product-link__text">{{ block.settings.product_button_text | default: slide_product.title }}</span>
                                        {%- else -%}
                                          <span class="sr-only">{{ block.settings.product_button_text | default: slide_product.title }}</span>
                                          {%- render 'icon' with 'cart', width: 14 -%}
                                        {%- endif -%}
                                      </a>
                                    {%- endif -%}

                                    <button type="button" class="carousel-video-sound-toggle circle-button" style="{{ control_button_style }}">
                                      <span class="sr-only">{{ 'general.accessibility.toggle_autoplay' | t }}</span>
                                      {%- render 'icon' with 'volume-off', width: 14, class: 'carousel-video-sound-off-icon' -%}
                                      {%- render 'icon' with 'volume', width: 14, class: 'carousel-video-sound-icon hidden' -%}
                                    </button>

                                    <button type="button" class="carousel-video-pause-toggle circle-button" style="{{ control_button_style }}">
                                      <span class="sr-only">{{ 'general.accessibility.toggle_autoplay' | t }}</span>
                                      {%- render 'icon' with 'slideshow-pause', width: 14, class: 'carousel-video-pause-icon' -%}
                                      {%- render 'icon' with 'slideshow-play', width: 14, class: 'carousel-video-play-icon hidden' -%}
                                    </button>
                                  </div>
                                {%- elsif slide_image != blank -%}
                                  {%- render 'media' with slide_image, sizes: '85vw', class: 'image-cover' -%}
                                {%- else -%}
                                  {{- 'hero-apparel-1' | placeholder_svg_tag: 'size-full' -}}
                                {%- endif -%}
                              </div>

                              {%- if slide_heading != blank or slide_text != blank -%}
                                <div class="place-self-center" style="max-width: 30rem">
                                  <div class="prose prose-justify-center">
                                    {%- if slide_heading != blank -%}
                                      {%- render 'heading', content: slide_heading, style: 'h3', html_tag: 'h3' -%}
                                    {%- endif -%}

                                    {%- if slide_text != blank -%}
                                      <div>{{ slide_text }}</div>
                                    {%- endif -%}
                                  </div>
                                </div>
                              {%- endif -%}
                            </div>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </product-list>
                    </div>

                    {%- if carousel_slide_count > 1 -%}
                      <progress-bar track-scroll-target="carousel-{{ block.id }}" class="progress-bar w-full"></progress-bar>
                    {%- endif -%}

                    {%- if carousel_slide_count >= 1 -%}
                      <script>
                        (function() {
                          var carousel = document.getElementById('carousel-{{ block.id }}');

                          if (!carousel) {
                            return;
                          }

                          customElements.whenDefined('product-list').then(function() {
                          var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
                          // Touch devices still autoplay muted like desktop, but the pause/play button stays
                          // hidden until the visitor unmutes (see isTouchDevice usage below) instead of
                          // appearing as soon as playback starts.
                          var isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
                          var advanceTimer;

                          function goToNext() {
                            if (carousel.selectedIndex >= carousel.cells.length - 1) {
                              carousel.select(0);
                            } else {
                              carousel.next();
                            }
                          }

                          function scheduleAdvance() {
                            clearTimeout(advanceTimer);

                            carousel.cells.forEach(function(cell) {
                              if (cell !== carousel.selectedCell) {
                                // Go through the <video-media> wrapper's own pause(), not the raw <video>
                                // tag directly: the wrapper tracks its own "playing" state and only the
                                // wrapper's play()/pause() keep that state (and the "loaded" attribute
                                // driving its CSS) in sync.
                                var otherVideoMedia = cell.querySelector('video-media');
                                if (otherVideoMedia) {
                                  otherVideoMedia.pause();
                                }
                              }
                            });

                            var videoMedia = carousel.selectedCell ? carousel.selectedCell.querySelector('video-media') : null;

                            if (videoMedia) {
                              // The video plays through once (no loop attribute) and its own 'ended' handler
                              // advances the carousel, so there is nothing to schedule here: moving on happens
                              // exactly when the video finishes, on every device.
                              videoMedia.play();
                            } else if (!reduceMotion) {
                              advanceTimer = setTimeout(goToNext, {{ block.settings.cycle_speed | times: 1000 }});
                            }
                          }

                          carousel.addEventListener('carousel:change', scheduleAdvance);
                          scheduleAdvance();

                          // Tracks the mute-setter of every video in this carousel, so that unmuting one can
                          // mute every other one (only one video can have sound at a time).
                          var muteSetters = [];

                          Array.prototype.forEach.call(carousel.querySelectorAll('.content-box__background-media'), function(mediaBox) {
                            var video = mediaBox.querySelector('video');

                            if (!video) {
                              return;
                            }

                            var videoMedia = mediaBox.querySelector('video-media');
                            var pauseButton = mediaBox.querySelector('.carousel-video-pause-toggle');
                            var pauseIcon = pauseButton.querySelector('.carousel-video-pause-icon');
                            var playIcon = pauseButton.querySelector('.carousel-video-play-icon');
                            var soundButton = mediaBox.querySelector('.carousel-video-sound-toggle');
                            var productLink = mediaBox.querySelector('.carousel-video-product-link');
                            var poster = mediaBox.querySelector('video-media > img');

                            // Comprar / Sonido / Play-Pausa fade in and out together, as a single group. On
                            // desktop they are simply always visible (see CSS) - no reveal logic needed here.
                            // On touch devices they start hidden and not focusable by keyboard until revealed
                            // (see setMuted below), and auto-hide again after a few seconds of inactivity.
                            var groupControls = productLink ? [soundButton, pauseButton, productLink] : [soundButton, pauseButton];
                            var INACTIVITY_HIDE_DELAY = 3000;
                            var inactivityTimer;

                            if (isTouchDevice) {
                              groupControls.forEach(function(control) {
                                control.tabIndex = -1;
                              });
                            }

                            function hideControls() {
                              groupControls.forEach(function(control) {
                                control.classList.remove('is-visible');
                                control.tabIndex = -1;
                              });
                            }

                            function scheduleHide() {
                              if (!isTouchDevice) {
                                return;
                              }

                              clearTimeout(inactivityTimer);
                              inactivityTimer = setTimeout(hideControls, INACTIVITY_HIDE_DELAY);
                            }

                            function revealControls() {
                              groupControls.forEach(function(control) {
                                control.classList.add('is-visible');
                                control.removeAttribute('tabindex');
                              });

                              scheduleHide();
                            }

                            video.addEventListener('playing', function() {
                              if (poster) {
                                poster.classList.add('carousel-video-poster-hidden');
                              }
                            });

                            pauseButton.addEventListener('click', function(event) {
                              event.stopPropagation();
                              revealControls();

                              if (videoMedia.playing) {
                                videoMedia.pause();
                              } else {
                                videoMedia.play();
                              }
                            });

                            video.addEventListener('playing', function() {
                              pauseIcon.classList.remove('hidden');
                              playIcon.classList.add('hidden');
                            });

                            video.addEventListener('pause', function() {
                              pauseIcon.classList.add('hidden');
                              playIcon.classList.remove('hidden');
                            });

                            // The video has no loop attribute, so it fires 'ended' once per playthrough. On
                            // touch devices this advances to the next slide (or wraps to the first) so the
                            // carousel cycles through every video, always starting the next one muted; with a
                            // single video slide, there is nowhere to advance to, so it just replays in place.
                            // On desktop the carousel never auto-advances: the video simply ends, and the
                            // visitor decides when to move on via the carousel's own navigation.
                            video.addEventListener('ended', function() {
                              if (!isTouchDevice) {
                                return;
                              }

                              if (carousel.cells.length > 1) {
                                goToNext();
                              } else {
                                videoMedia.play();
                              }
                            });

                            var soundOffIcon = soundButton.querySelector('.carousel-video-sound-off-icon');
                            var soundOnIcon = soundButton.querySelector('.carousel-video-sound-icon');

                            function setMuted(muted) {
                              video.muted = muted;
                              soundOffIcon.classList.toggle('hidden', !muted);
                              soundOnIcon.classList.toggle('hidden', muted);

                              // On touch devices, unmuting is what hands control over to the whole custom
                              // control group (on desktop it is simply always visible, see CSS). Once
                              // revealed it stays revealed, even if the visitor mutes again afterwards.
                              if (!muted && isTouchDevice) {
                                revealControls();
                              }
                            }

                            function toggleSound() {
                              var wasMuted = video.muted;

                              if (wasMuted) {
                                muteSetters.forEach(function(otherSetMuted) {
                                  if (otherSetMuted !== setMuted) {
                                    otherSetMuted(true);
                                  }
                                });
                              }

                              setMuted(!wasMuted);
                            }

                            muteSetters.push(setMuted);

                            soundButton.addEventListener('click', function(event) {
                              event.stopPropagation();
                              revealControls();
                              toggleSound();
                            });

                            // The "go to product" link navigates on its own; it just needs to not also
                            // trigger the tap-to-unmute handler below.
                            if (productLink) {
                              productLink.addEventListener('click', function(event) {
                                event.stopPropagation();
                                revealControls();
                              });
                            }

                            // Tolstoy-style tap-to-unmute: tapping anywhere on the video (not just the small
                            // sound button) toggles sound in place, matching how Tolstoy's thumbnail behaves.
                            // Also counts as interaction for the mobile inactivity auto-hide timer.
                            mediaBox.addEventListener('click', function() {
                              revealControls();
                              toggleSound();
                            });
                          });
                          });
                        })();
                      </script>
                    {%- endif -%}
                  </div>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.media_blocks.name",
  "class": "shopify-section--media-blocks",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "allow_transparent_header",
      "label": "t:global.section.allow_transparent_header",
      "info": "t:global.section.allow_transparent_header_info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.media_blocks.content_category"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "t:global.text.subheading"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:global.text.heading",
      "default": "Media blocks"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:global.text.content",
      "default": "<p>Use this section to create rich content by using images, videos, scrolling text or horizontal text. If textual content is more important than imagery, consider using the multi column section instead.</p>"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:global.text.heading_size",
      "options": [
        {
          "value": "display-xl",
          "label": "Display XL"
        },
        {
          "value": "display-l",
          "label": "Display L"
        },
        {
          "value": "display-m",
          "label": "Display M"
        },
        {
          "value": "h1",
          "label": "XX-Large"
        },
        {
          "value": "h2",
          "label": "X-Large"
        },
        {
          "value": "h3",
          "label": "Large"
        },
        {
          "value": "h4",
          "label": "Medium"
        },
        {
          "value": "h5",
          "label": "Small"
        },
        {
          "value": "h6",
          "label": "X-Small"
        },
        {
          "value": "h7",
          "label": "XX-Small"
        }
      ],
      "default": "h4"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "label": "t:global.text.alignment"
    },
    {
      "type": "checkbox",
      "id": "scrolling_title",
      "label": "t:sections.media_blocks.show_scrolling_title"
    },
    {
      "type": "select",
      "id": "scrolling_title_separator",
      "label": "t:sections.media_blocks.scrolling_title_separator",
      "options": [
        {
          "value": "none",
          "label": "t:sections.media_blocks.scrolling_title_separator_options.none"
        },
        {
          "value": "circle",
          "label": "t:sections.media_blocks.scrolling_title_separator_options.circle"
        },
        {
          "value": "square",
          "label": "t:sections.media_blocks.scrolling_title_separator_options.square"
        },
        {
          "value": "diamond",
          "label": "t:sections.media_blocks.scrolling_title_separator_options.diamond"
        }
      ],
      "default": "circle"
    },
    {
      "type": "header",
      "content": "t:sections.media_blocks.blocks_category"
    },
    {
      "type": "checkbox",
      "id": "stack_on_mobile",
      "label": "t:sections.multi_column.stack_on_mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "add_horizontal_spacing",
      "label": "t:global.spacing.add_horizontal_spacing",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "add_border",
      "label": "t:sections.media_blocks.add_border",
      "default": false
    },
    {
      "type": "select",
      "id": "column_spacing",
      "label": "t:global.spacing.spacing",
      "options": [
        {
          "value": "none",
          "label": "t:global.spacing.spacing_options.none"
        },
        {
          "value": "sm",
          "label": "t:global.spacing.spacing_options.small"
        },
        {
          "value": "md",
          "label": "t:global.spacing.spacing_options.medium"
        },
        {
          "value": "lg",
          "label": "t:global.spacing.spacing_options.large"
        }
      ],
      "default": "sm"
    },
    {
      "type": "checkbox",
      "id": "auto_corner_radius",
      "label": "Automatic corner radius",
      "info": "Scales the corner radius responsively based on screen size, up to the value set below.",
      "default": true
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 23,
      "step": 1,
      "unit": "px",
      "label": "Corner radius",
      "info": "Applied only to the outer corners of the first and last card.",
      "default": 12
    },
    {
      "type": "range",
      "id": "items_per_row",
      "min": 2,
      "max": 4,
      "label": "t:sections.media_blocks.items_per_row",
      "default": 2
    },
    {
      "type": "select",
      "id": "block_size",
      "label": "t:sections.media_blocks.block_size",
      "options": [
        {
          "value": "auto",
          "label": "t:global.sizes.original_image_ratio"
        },
        {
          "value": "sm",
          "label": "t:global.sizes.small"
        },
        {
          "value": "md",
          "label": "t:global.sizes.medium"
        },
        {
          "value": "lg",
          "label": "t:global.sizes.large"
        },
        {
          "value": "fill",
          "label": "t:global.sizes.fit_screen"
        }
      ],
      "info": "t:global.image.ratio_avoid_cropping_info",
      "default": "auto"
    },
    {
      "type": "select",
      "id": "mobile_block_size",
      "label": "Mobile block size",
      "options": [
        {
          "value": "auto",
          "label": "t:global.sizes.original_image_ratio"
        },
