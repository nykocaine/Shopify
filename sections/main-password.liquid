{%- capture section_main_content -%}
  <div class="password-password-main w-full">
    <div class="password-password-main__inner">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'logo' -%}
            {%- capture logo_content -%}
              {%- if block.settings.image != blank -%}
                {%- capture sizes -%}{{ block.settings.max_width }}px{%- endcapture -%}
                {%- capture widths -%}{{ block.settings.max_width | times: 2 | at_most: block.settings.image.width }}, {{ block.settings.max_width | times: 3 | at_most: block.settings.image.width }}{%- endcapture -%}
                {%- capture style -%}--image-mobile-max-width: {{ block.settings.mobile_max_width }}px; --image-max-width: {{ block.settings.max_width }}px{%- endcapture -%}

                <span class="sr-only">{{ shop.name }}</span>
                {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: style: style, sizes: sizes, widths: widths, class: 'constrained-image' -}}
              {%- else -%}
                <span class="h4">{{ shop.name }}</span>
              {%- endif -%}
            {%- endcapture -%}

            <h1 class="password-password-main__logo" {{ block.shopify_attributes }}>{{- logo_content -}}</h1>

          {%- when 'content' -%}
            <div class="password-password-main__content w-full max-w-xs mx-auto">
              <div class="v-stack gap-8 sm:gap-10">
                <div class="v-stack gap-4 sm:gap-6">
                  {%- if shop.password_message != blank -%}
                    <div class="prose prose-justify-center text-center">
                      <p>{{ shop.password_message }}</p>
                    </div>
                  {%- endif -%}

                  <div class="v-stack gap-4">
                    {%- form 'customer', class: 'fieldset' -%}
                      {%- if form.posted_successfully? -%}
                        {%- assign success_message = 'general.newsletter.subscribed_successfully' | t -%}
                        {%- render 'banner', status: 'success', content: success_message, text_alignment: 'center' -%}
                      {%- else -%}
                        {%- if form.errors -%}
                          {%- capture error_message -%}{{ form.errors.translated_fields['email'] }} {{ form.errors.messages['email'] }}{%- endcapture -%}
                          {%- render 'banner', status: 'error', content: error_message -%}
                        {%- endif -%}

                        <input type="hidden" name="contact[tags]" value="newsletter">

                        {%- assign email_label = 'general.newsletter.email' | t -%}
                        {%- render 'input', type: 'email', name: 'contact[email]', label: email_label, required: true -%}

                        {%- assign submit_button = 'general.newsletter.notify_me' | t -%}
                        {%- render 'button', type: 'submit', content: submit_button, stretch: true -%}
                      {%- endif -%}
                    {%- endform -%}

                    <button aria-controls="access-storefront-modal" class="justify-self-center link text-center">
                      {{- 'password.storefront_access.enter_password' | t -}}
                    </button>

                    {%- liquid
                      assign has_form_errors = false

                      capture storefront_form
                        form 'storefront_password', class: 'fieldset'
                          if form.errors
                            assign has_form_errors = true
                            render 'banner', status: 'error', content: form.errors.messages['form'], text_alignment: 'center'
                          endif

                          assign password_label = 'password.storefront_access.password' | t
                          assign submit_label = 'password.storefront_access.enter_store' | t

                          render 'input', type: 'password', name: 'password', label: password_label, required: true
                          render 'button', type: 'submit', content: submit_label, stretch: true
                        endform
                      endcapture
                    -%}

                    <x-modal {% if has_form_errors %}open{% endif %} id="access-storefront-modal" class="modal color-scheme color-scheme--{{ settings.default_color_scheme.id }}">
                      <div class="v-stack gap-6 text-center">
                        <div class="v-stack justify-items-center gap-4">
                          {%- render 'icon' with 'lock' -%}
                          <p class="h4">{{ 'password.storefront_access.store_access' | t }}</p>
                        </div>

                        <p>{{ 'password.storefront_access.instructions' | t }}</p>

                        {{- storefront_form -}}
                      </div>
                    </x-modal>
                  </div>
                </div>

                {%- capture social_media -%}{%- render 'social-media' -%}{%- endcapture -%}

                {%- if block.settings.show_social_media and social_media != blank -%}
                  <hr>

                  <div class="v-stack justify-items-center gap-5 text-center">
                    <p>{{ 'password.general.follow_us' | t }}</p>
                    {{- social_media -}}
                  </div>
                {%- endif -%}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
{%- endcapture -%}

{%- liquid
  assign has_image_content = false
  if section.settings.background_image != blank or section.settings.image_rotating_text != blank
    assign has_image_content = true
  endif
-%}

{%- style -%}
  .password-section-shell {
    min-height: 100vh;
  }

  .password-section-shell--single {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.25rem;
  }

  .password-section-shell--split {
    min-height: 100vh;
  }

  .password-password-main {
    width: 100%;
    padding-inline: 1.25rem;
  }

  .password-password-main__inner {
    width: 100%;
    max-width: 30rem;
    margin-inline: auto;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .password-password-main__logo {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-bottom: 1.5rem;
  }

  .password-password-main__content {
    width: 100%;
  }

  @media screen and (min-width: 700px) {
    .password-section-shell--single {
      padding: 3rem;
    }

    .password-password-main {
      padding-inline: 2rem;
    }
  }

  {%- if section.settings.floating_password -%}
    #shopify-section-{{ section.id }} .password-section-shell,
    #shopify-section-{{ section.id }} .password-section-shell--split {
      min-height: calc(100vh - (var(--container-gutter) * 2));
    }
  {%- endif -%}
{%- endstyle -%}

<div class="color-scheme color-scheme--{{ section.settings.content_color_scheme.id }}{% if section.settings.floating_password %} section-floating section-floating--block{% endif %}">
  {%- if section.settings.show_image_panel and has_image_content -%}
    <div class="section-split password-section-shell password-section-shell--split sm:min-h-fill">
      <div class="section-split__column section-split__column--image section-split__column--flushed hidden sm:block">
        <div class="content-box h-full min-h-sm color-scheme color-scheme--{{ section.settings.image_color_scheme.id }}">
          {%- if section.settings.background_image != blank -%}
            <div class="content-box__background-media">
              {{- section.settings.background_image | image_url: width: section.settings.background_image.width | image_tag: sizes: '(max-width: 699px) 100vw, 50vw', widths: '200,300,400,600,800,1000,1200,1400,1600,1800,2000' -}}
            </div>
          {%- endif -%}

          {%- if section.settings.image_rotating_text != blank -%}
            <div class="column-span-full align-self-center">
              <marquee-text speed="0.1" direction="start-to-end" class="scrolling-content">
                <div class="scrolling-content__item" style="font-size: var(--text-h1)">
                  <p class="h1">{{ section.settings.image_rotating_text }}</p>
                </div>
              </marquee-text>

              <marquee-text speed="0.1" direction="end-to-start" class="scrolling-content">
                <div class="scrolling-content__item" style="font-size: var(--text-h1)">
                  <p class="h1">{{ section.settings.image_rotating_text }}</p>
                </div>
              </marquee-text>
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="section-split__column password-section-shell password-section-shell--single align-self-center">
        {{- section_main_content -}}
      </div>
    </div>
  {%- else -%}
    <div class="password-section-shell password-section-shell--single">
      {{- section_main_content -}}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Password",
  "class": "shopify-section--main-password",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_image_panel",
      "label": "Mostrar panel de imagen",
      "info": "Activa o desactiva la columna izquierda de imagen.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "floating_password",
      "label": "Floating Password",
      "info": "Adds margins around the password page (top, bottom and sides), using the store's global side margin.",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "image_color_scheme",
      "label": "Image color scheme",
      "default": "scheme-4"
    },
    {
      "type": "color_scheme",
      "id": "content_color_scheme",
      "label": "Content color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Recommended size for the password page background image"
    },
    {
      "type": "inline_richtext",
      "id": "image_rotating_text",
      "label": "Image rotating text",
      "default": "Opening Soon"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image",
          "info": "Recommended size for the password page logo"
        },
        {
          "type": "range",
          "id": "max_width",
          "min": 50,
          "max": 300,
          "step": 5,
          "unit": "px",
          "label": "Desktop width",
          "default": 140
        },
        {
          "type": "range",
          "id": "mobile_max_width",
          "min": 50,
          "max": 170,
          "step": 5,
          "unit": "px",
          "label": "Mobile width",
          "default": 100
        }
      ]
    },
    {
      "type": "content",
      "name": "Content",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Newsletter form and password access."
        },
        {
          "type": "checkbox",
          "id": "show_social_media",
          "label": "Show social media",
          "info": "Display social media links if available.",
          "default": true
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "logo"
      },
      {
        "type": "content"
      }
    ]
  }
}
{% endschema %}